# --- Repo Recall configuration ---

# Runtime
APP_ENV=dev

# PRFactory-style runtime mode compatibility
# - MOCK_MODE=true disables embeddings even if OPENAI_API_KEY is set
# - AUTH_MODE=disabled (no auth) or api_token (requires API_AUTH_TOKEN)
MOCK_MODE=true
AUTH_MODE=disabled

# Postgres connection string (pgvector extension required)
# Example for docker-compose:
# DATABASE_URL=postgresql://repo_recall:repo_recall@localhost:5432/repo_recall
DATABASE_URL=postgresql://repo_recall:repo_recall@localhost:5432/repo_recall
# Optional alias used by hosted Postgres providers (Neon/Supabase):
# NEON_CONNECTION_STRING=postgresql://...
# When both are present, NEON_CONNECTION_STRING takes precedence.

# OpenAI API key (optional if using lexical-only mode)
OPENAI_API_KEY=

# Embeddings model
EMBEDDING_MODEL=text-embedding-3-small
# Embedding vector dimension (DB schema must match)
EMBEDDING_DIM=1536

# Max size for files to index (bytes)
MAX_FILE_BYTES=800000

# Chunking
MAX_CHUNK_CHARS=8000
CHUNK_OVERLAP_LINES=20

# Indexing cache directory for cloned repos
REPO_CACHE_DIR=.cache/repos

# API auth token
# When AUTH_MODE=api_token, clients must pass either:
# - Authorization: Bearer <token>
# - X-FF-Token: <token>
API_AUTH_TOKEN=

# Service behavior
INIT_DB_ON_STARTUP=true
# If true, startup exits on DB/job/scheduler init failures.
# For Cloud Run, keep false to let /health and /health/runtime come up for debugging.
FAIL_FAST_STARTUP=false
ENABLE_UI=true
JOB_WORKERS=1

# Security
ENABLE_SECRET_REDACTION=true

# GitHub catalog
ENABLE_CATALOG=true
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=
GITHUB_CONNECT_URL_TEMPLATE=/connect/github?actor_id={actor_id}
GITHUB_TOKEN_BROKER_URL=
GITHUB_TOKEN_BROKER_AUTH_TOKEN=
CATALOG_SYNC_INTERVAL_SECONDS=3600
CATALOG_REPO_PAGE_SIZE=100
CATALOG_BRANCH_PAGE_SIZE=100
CATALOG_REQUEST_TIMEOUT_SECONDS=20
ENABLE_CATALOG_DEV_ENDPOINTS=false
